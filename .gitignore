# Local .terraform directories
**/.terraform/
**/.terraform.lock.hcl

# .tfstate files (File trạng thái chứa thông tin nhạy cảm và mapping tài nguyên)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (Thường chứa bí mật/password)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# SSH Keys (Nếu bạn để key pem trong thư mục dự án)
*.pem

# Editor specific files
.vscode/
.idea/
*.DS_Store